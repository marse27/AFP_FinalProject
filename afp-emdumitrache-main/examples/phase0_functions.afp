// Phase 0: multi parameter functions and mutable parameters.
// double(3) = 6, no_arg() = 42, plus(6, 42) = 48.
// Expected output: 48
fn double(x: int) -> int {
    x + x
};
fn plus(x: int, y: int) -> int {
    x + y
};
fn double_in_place(mut x: int) -> int {
    x = x * 2;
    x
};
fn no_arg() -> int {
    42
};
plus(double(3), no_arg())
