// Phase 2C: Result type and pattern matching.
// safe_div returns Ok(42) for safe_div(84, 2); the match extracts the value.
// A division by zero would return Err(0) instead.
// Expected output: 42

fn safe_div(x: int, y: int) -> Result<int> {
    if y == 0 then Err(0) else Ok(x / y)
};
let r = safe_div(84, 2);
match r { Ok(v) => v, Err(e) => e }
